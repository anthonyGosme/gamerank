# Copier vers .env — valeurs par défaut adaptées au docker-compose local
DATABASE_URL=postgres://gamerank:gamerank@localhost:5432/gamerank
# APP_URL=http://localhost:3000  # défaut : dérivée de PORT
# PORT=3000
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=gamerank
CLICKHOUSE_PASSWORD=gamerank
CLICKHOUSE_DB=gamerank
# Dev : Mailpit capture les emails (pas d'auth, UI sur http://localhost:8025).
# Prod : voir doc/EMAIL-SETUP.md (Resend / SES) — renseigner USER/PASS.
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_SECURE=true          # forcer le TLS direct (auto si port 465)
# SMTP_USER=resend          # Resend : littéralement "resend"
# SMTP_PASS=re_xxxxxxxx      # Resend : la clé API
MAIL_FROM="WebGameRank <no-reply@webgamerank.local>"
NODE_ENV=development
# Emails autorisés sur /admin (séparés par des virgules)
ADMIN_EMAILS=
# Pipeline agrégation + scoring, en secondes (0 = désactivé)
PIPELINE_INTERVAL_SECONDS=30
